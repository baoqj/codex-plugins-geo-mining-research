# PFLOTRAN input deck skeleton generated by GeoMine Research.
# This is not a validated executable model.

SIMULATION
  SIMULATION_TYPE SUBSURFACE
  PROCESS_MODELS
    SUBSURFACE_FLOW flow
      MODE <RICHARDS_OR_SUBSURFACE_FLOW_MODE>
    /
    SUBSURFACE_TRANSPORT transport
      MODE <TRANSPORT_OR_REACTIVE_TRANSPORT_MODE>
    /
  /
END

SUBSURFACE
  GRID
    TYPE structured
    NXYZ <nx> <ny> <nz>
    BOUNDS
      <xmin> <ymin> <zmin>
      <xmax> <ymax> <zmax>
    /
  END

  REGION all
    COORDINATES
      <xmin> <ymin> <zmin>
      <xmax> <ymax> <zmax>
    /
  END

  MATERIAL_PROPERTY material_1
    ID 1
    POROSITY <porosity>
    TORTUOSITY <tortuosity>
    PERMEABILITY
      PERM_ISO <permeability_m2>
    /
  END

  FLOW_CONDITION initial_flow
    TYPE <pressure_or_head>
    PRESSURE <initial_pressure>
  END

  TRANSPORT_CONDITION initial_transport
    TYPE dirichlet
    CONSTRAINT_LIST
      0.d0 initial_constraint
    /
  END

  CHEMISTRY
    PRIMARY_SPECIES
      <primary_species>
    /
    SECONDARY_SPECIES
      <secondary_species>
    /
    MINERALS
      <minerals>
    /
  END

  OUTPUT
    TIMES y <output_times>
    FORMAT HDF5
    VARIABLES
      LIQUID_PRESSURE
      LIQUID_SATURATION
      TOTAL_CONCENTRATION <species>
      PH
      POROSITY
    /
  END
END_SUBSURFACE
